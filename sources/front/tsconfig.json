{
    "compilerOptions": {
        // Général
        "lib": ["es2023", "dom"],
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "target": "es2023",
        "sourceMap": true,

        // Options additionnelles
        "importHelpers": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedSideEffectImports": false,
        "noUnusedLocals": true,
        "noUnusedParameters": true,

        "skipDefaultLibCheck": true,
        "skipLibCheck": true,
        "types": []
    }
}
